{
  "openapi": "3.0.3",
  "info": {
    "title": "FidelityBridge API",
    "description": "Financial data bridging and account aggregation",
    "version": "1.0.0",
    "x-category": "Financial",
    "x-long-description": "The FidelityBridge API provides production-ready financial data bridging and account aggregation. Fully compatible with RapidAPI marketplace, ready for monetization.",
    "x-badges": [
      {
        "name": "production-ready",
        "color": "green"
      },
      {
        "name": "finance",
        "color": "blue"
      }
    ],
    "x-rapidapi-config": {
      "has_api_key": true,
      "api_key_header": "x-api-key",
      "default_api_key": "rapidapi_live_key_fidelitybridge"
    }
  },
  "servers": [
    {
      "url": "https://fidelitybridge-api-production.up.railway.app",
      "description": "Production (Railway)"
    }
  ],
  "paths": {
